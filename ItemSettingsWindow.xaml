<Window x:Class="YouTubeDownloader.ItemSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Item Settings" Height="320" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#282A36" Foreground="White"
        FontFamily="Segoe UI Variable" FontSize="14">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- URL -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Download URL" FontWeight="Bold" Foreground="#FFB86C"/>
            <TextBox x:Name="UrlText" MinWidth="460"/>
        </StackPanel>

        <!-- Type -->
        <StackPanel Grid.Row="1" Margin="0,8,0,8">
            <TextBlock Text="Download Type" FontWeight="Bold" Foreground="#FFB86C"/>
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <RadioButton x:Name="RbFullVideo" Content="Full Video" Margin="0,0,10,0"/>
                <RadioButton x:Name="RbVideoSegment" Content="Video Segment" Margin="0,0,10,0"/>
                <RadioButton x:Name="RbFullAudio" Content="Full Audio" Margin="0,0,10,0"/>
                <RadioButton x:Name="RbAudioSegment" Content="Audio Segment"/>
            </StackPanel>
        </StackPanel>

        <!-- Segment Times -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,8,0,8">
            <TextBlock Text="Start" Margin="0,5,6,0"/>
            <TextBox x:Name="StartText" Width="100"/>
            <TextBlock Text="End" Margin="12,5,6,0"/>
            <TextBox x:Name="EndText" Width="100"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="ResetButton" Content="Reset to Queued" Width="140" Margin="0,0,8,0" Click="ResetButton_Click" Background="#FFB86C" Foreground="#282A36"/>
            <Button Content="Save" Width="100" Click="Save_Click" Background="#50FA7B" Foreground="#282A36"/>
            <Button Content="Cancel" Width="100" Click="Cancel_Click" Background="#FF5555" Foreground="#282A36"/>
        </StackPanel>
    </Grid>
</Window>

