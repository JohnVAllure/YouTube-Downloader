    <Application x:Class="YouTubeDownloader.App"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    StartupUri="MainWindow.xaml">

    <Application.Resources>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#50FA7B"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2A2A2A"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#2D2D30"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#F8F8F2"/>

            <Style TargetType="Button">
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="Height" Value="35"/>
                <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#44475A"/>
                <Setter Property="Foreground" Value="#F8F8F2"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6272A4"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
                <Setter Property="Foreground" Value="#282A36"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF79C6"/>
                </Trigger>
                </Style.Triggers>
        </Style>


        <!-- Modern TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
        <Setter Property="Background" Value="#44475A"/>
            <Setter Property="Foreground" Value="#F8F8F2"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="CaretBrush" Value="#F8F8F2"/>
            <Setter Property="Padding" Value="6,2"/>
        </Style>

            <!-- Modern RadioButton -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="16" Height="16" Margin="0,0,6,0">
                                <Ellipse Fill="#44475A" />
                                <Ellipse x:Name="InnerDot" Width="10" Height="10" Fill="#F1FA8C" Visibility="Collapsed"/>
                            </Grid>
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="InnerDot" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="#F1FA8C"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="InnerDot" Property="Fill" Value="#FFB86C"/>
                                <Setter Property="Foreground" Value="#FFB86C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListView Styling -->
        <Style TargetType="ListView">
            <Setter Property="Background" Value="#282A36"/>
            <Setter Property="Foreground" Value="#F8F8F2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                </Trigger>
            </Style.Triggers>
        </Style>

            <!-- ListView Header -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#282A36"/>
            <Setter Property="Foreground" Value="#F8F8F2"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#666"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter
                            Margin="5"
                            VerticalAlignment="Center"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            RecognizesAccessKey="True"/>
                            </Border>

                            <!-- Thumb for column resizing -->
                            <Thumb x:Name="PART_HeaderGripper"
                            HorizontalAlignment="Right"
                            Width="1"
                            Style="{x:Null}"
                            Background="Transparent"
                            Cursor="SizeWE"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- ListView Row Styling -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#F8F8F2"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="#444"
                            BorderThickness="0,0,0,1">
                                <GridViewRowPresenter
                            Content="{TemplateBinding Content}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            SnapsToDevicePixels="True">
                                <GridViewRowPresenter.Columns>
                                    <Binding Path="View.Columns"
                                    RelativeSource="{RelativeSource AncestorType=ListView}"
                                    FallbackValue="{x:Null}"/>
                                </GridViewRowPresenter.Columns>
                            </GridViewRowPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover Effect -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#282A36"/>
                            </Trigger>
                            <!-- Selected Effect -->
                            <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#44475A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        <!-- Color by status -->
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Queued">
                    <Setter Property="Foreground" Value="#F8F8F2"/>
                    <!-- dark gray -->
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Downloading">
                    <Setter Property="Foreground" Value="#FFC77E"/>
                    <!-- warm orange tone -->
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Completed">
                    <Setter Property="Foreground" Value="#8EFF9B"/>
                    <!-- greenish -->
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Failed">
                    <Setter Property="Foreground" Value="#FF5D5D"/>
                    <!-- red tint -->
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollBar" x:Key="ModernVerticalScrollBar" BasedOn="{StaticResource {x:Type ScrollBar}}">
            <Setter Property="Width" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Up Button -->
                            <RepeatButton Grid.Row="0" Height="12" Command="ScrollBar.LineUpCommand" Padding="0,5,0,0">
                                <RepeatButton.Template>
                                    <ControlTemplate TargetType="RepeatButton">
                                        <Border x:Name="Border" Background="Transparent">
                                            <Path Data="M 0 4 L 5 0 L 9 4"
                                              Stroke="#FF79C6"
                                              StrokeThickness="2"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#44475A"/>
                                                <!-- Hover background -->
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#6272A4"/>
                                                <!-- Pressed background -->
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RepeatButton.Template>
                            </RepeatButton>


                            <!-- Thumb -->
                            <Track Name="PART_Track" Grid.Row="1" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb Width="12" HorizontalAlignment="Center">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border
                                                    Background="#FF79C6"
                                                    Width="7"
                                                    CornerRadius="4"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Stretch"
                                                    Margin="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>


                            <!-- Down Button -->
                            <RepeatButton Grid.Row="2" Height="12" Command="ScrollBar.LineDownCommand" Padding="0,0,0,5">
                                <RepeatButton.Template>
                                    <ControlTemplate TargetType="RepeatButton">
                                        <Border x:Name="Border" Background="Transparent">
                                            <Path Data="M 0 0 L 5 4 L 9 0"
                                            Stroke="#FF79C6"
                                            StrokeThickness="2"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#44475A"/>
                                                <!-- Hover background -->
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#6272A4"/>
                                                <!-- Pressed background -->
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RepeatButton.Template>
                            </RepeatButton>

                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- Minimal Button style for the arrow buttons -->
        <Style x:Key="ScrollBarLineButton" TargetType="RepeatButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>  
