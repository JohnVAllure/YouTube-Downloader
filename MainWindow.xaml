<Window x:Class="YouTubeDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YouTube Downloader" Height="600" MinHeight="400" Width="800" MinWidth="800"
        ResizeMode="NoResize"
        Background="#21222A" Foreground="#E0E0E0"
        FontFamily="Segoe UI Variable" FontSize="14">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
            <RowDefinition Height="Auto"/>
            <!-- Download Type + Times -->
            <RowDefinition Height="*"/>
            <!-- Download Queue -->
            <RowDefinition Height="Auto"/>
            <!-- Bottom Buttons -->
        </Grid.RowDefinitions>

        <!-- Clipboard & Multi-Link Buttons -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- === LEFT: Download Type === -->
            <StackPanel Orientation="Vertical" Grid.Column="0" Margin="5,0,0,0">
                <TextBlock Text="Choose Download Type:" FontWeight="Bold" Margin="0,5,0,5" Foreground="#FFB86C"/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                    <RadioButton x:Name="FullVideoRadio" Content="Full Video" ToolTip="Download The Full Length Video" IsChecked="True" Margin="0,0,10,0"/>
                    <RadioButton x:Name="VideoSegmentRadio" Content="Video Segment" ToolTip="Download only part of the video by specifying the Start and End time" Margin="0,0,10,0"/>
                    <RadioButton x:Name="FullAudioRadio" Content="Full Audio" ToolTip="Download The Full Length Audio" Margin="0,0,10,0"/>
                    <RadioButton x:Name="AudioSegmentRadio" Content="Audio Segment" ToolTip="Download only part of the audio by specifying the Start and End time"/>
                </StackPanel>

                <StackPanel x:Name="SegmentTimePanel" Orientation="Horizontal" Margin="0,5,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Start Time:" Margin="0,5,5,0" Foreground="#F8F8F2"/>
                    <TextBox x:Name="StartTimeBox" Width="100" PreviewTextInput="TimeBox_PreviewTextInput" TextChanged="SegmentTimeBox_TextChanged" Text="00:00:00"/>
                    <TextBlock Text="End Time:" Margin="10,5,5,0" Foreground="#F8F8F2"/>
                    <TextBox x:Name="EndTimeBox" Width="100" PreviewTextInput="TimeBox_PreviewTextInput" TextChanged="SegmentTimeBox_TextChanged" Text="00:05:00"/>

                    <!-- Duration display -->
                    <TextBlock x:Name="SegmentDurationText" Margin="10,7,0,3" Foreground="#8AFF8A" FontWeight="Bold"/>
                </StackPanel>

            </StackPanel>

            <!-- === RIGHT: Buttons === -->
            <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Top" ToolTip="Paste link from clipboard">
                <!-- Paste + Add Group -->
                <StackPanel Orientation="Horizontal">
                    <Button Width="40" Height="40" Click="PasteLinkButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#8BE9FD"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFB86C"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Border Background="Black" Width="20" Height="20">
                            <Border.OpacityMask>
                                <ImageBrush ImageSource="/Assets/paste.png"/>
                            </Border.OpacityMask>
                        </Border>
                    </Button>

                    <Button Width="40" Height="40" ToolTip="Add multiple links" Margin="4,0,14,0" Click="AddLinksButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#8BE9FD"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFB86C"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content>
                            <Border Background="Black" Width="20" Height="20">
                                <Border.OpacityMask>
                                    <ImageBrush ImageSource="/Assets/add.png" />
                                </Border.OpacityMask>
                            </Border>
                        </Button.Content>
                    </Button>

                </StackPanel>

                <!-- Settings (outside group) -->
                <Button Width="42" Height="42" ToolTip="Settings" Click="SettingsButton_Click">
                    <Image Source="/Assets/settings.png" Width="20" Height="20"/>
                </Button>
            </StackPanel>
        </Grid>

        <TextBlock x:Name="EmptyHintText"
           Grid.Row="2"
           Text="Press Ctrl+V or click  to add links"
           Foreground="#888"
           FontSize="26"
           FontWeight="Bold"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"
           Visibility="Collapsed"
           TextAlignment="Center"/>
        
        <!-- Downloads Queue List -->
        <ListView x:Name="DownloadsListView" Loaded="DownloadsListView_Loaded" ScrollViewer.ScrollChanged="DownloadsListView_ScrollChanged" 
                  Background="#282A36" Foreground="#F8F8F2" BorderBrush="Transparent" BorderThickness="0" FocusVisualStyle="{x:Null}" 
                  SnapsToDevicePixels="True" ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                  ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.CanContentScroll="True" 
                  VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                  Grid.Row="2" Margin="0,0,0,10">
            <ListView.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource ModernVerticalScrollBar}" />
            </ListView.Resources>
            <ListView.View>
                <GridView x:Name="DownloadsGridView">
                    <GridViewColumn Header="#" Width="40">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding RowNumber}" TextAlignment="Center" Foreground="#FF5555"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn x:Name="TitleColumn" Header="Title / Link" Width="450">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical" Margin="0">
                                    <!-- Video Title -->
                                    <TextBlock Text="{Binding VideoTitle}" 
                           FontSize="13"
                           Foreground="#F1FA8C" 
                           TextTrimming="CharacterEllipsis" />

                                    <!-- Link (URL) -->
                                    <TextBlock Text="{Binding DisplayTitle}" 
                           FontSize="12" 
                           Foreground="#8BE9FD" 
                           TextTrimming="CharacterEllipsis" />

                                    <!-- Download Info -->
                                    <TextBlock FontSize="11" Foreground="#F8F8F2">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} {1}">
                                                <Binding Path="DownloadType" />
                                                <Binding Path="FormattedSegment" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>


                    <GridViewColumn Header="Status" Width="190">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <ProgressBar x:Name="Spinner" Width="60" Height="6" IsIndeterminate="True" Visibility="Collapsed"/>
                                        <TextBlock Text="{Binding Status}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3,0,0">
                                        <Button Content="Retry" Visibility="{Binding RetryVisible}" Click="Retry_Click"
                                                Width="48" Height="18" FontSize="10" Margin="2,0"/>
                                        <Button Content="Details" Visibility="{Binding ErrorVisible}" Click="ShowError_Click"
                                                Width="48" Height="18" FontSize="10" Margin="2,0"/>
                                        <Button Content="Open" Visibility="{Binding OpenVisible}" Click="OpenFolder_Click"
                                                Width="48" Height="18" FontSize="10" Margin="2,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                        <Setter TargetName="Spinner" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Preparing">
                                        <Setter TargetName="Spinner" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Converting to MP4">
                                        <Setter TargetName="Spinner" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Options" Width="82">
                        <GridViewColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <!-- Settings Button -->
                                <Button Width="30" Height="30" ToolTip="Settings" Background="#BD93F9" Click="SettingsButton_Click">
                                    <Image Source="/Assets/settings.png" Width="20" Height="20"/>
                                </Button>

                                <!-- Remove Button -->
                                <Button Width="30" Height="30" ToolTip="Remove" Background="#FF5D5D" Click="RemoveItem_Click">
                                    <Image Source="/Assets/cancel.png" Width="20" Height="20"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Bottom Buttons -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Clear button on the Right -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="ClearButton" Content="Clear" Width="80" Click="ClearButton_Click" />
                <TextBlock x:Name="StatusMessageTextBlock"
           Grid.Row="4"
           Margin="10,0,0,0"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"
           Foreground="#FFD866"
           FontSize="14"
           Opacity="0"
           Text=""
           TextAlignment="Center"/>
            </StackPanel>

            <!-- Start button on the right -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" >
                <Button x:Name="OpenDownloadsFolderButton" Content="Open Downloads Folder" Width="170"
                        Click="OpenDownloadsFolderButton_Click" />
                <Button x:Name="StartDownloadButton" Content="Start Downloads" Width="150" 
                        Style="{StaticResource PrimaryButtonStyle}" Click="StartDownloadButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
