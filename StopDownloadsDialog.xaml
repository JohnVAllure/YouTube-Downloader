<Window x:Class="YouTubeDownloader.StopDownloadsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stop Downloads" Height="180" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#282A36" Foreground="White"
        FontFamily="Segoe UI Variable" FontSize="14">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock TextWrapping="Wrap"
                   Text="How would you like to stop downloads?"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Finish Active Then Stop" Width="190" Margin="0,0,8,0" Click="FinishActive_Click"/>
            <Button Content="Stop Now" Width="110" Background="#FF5555" Foreground="#282A36" Click="StopNow_Click"/>
        </StackPanel>
    </Grid>
</Window>

