<Window x:Class="YouTubeDownloader.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#282A36" Foreground="White"
        FontFamily="Segoe UI Variable" FontSize="14" Width="740" Height="620">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Download Directory -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Download Directory" FontWeight="Bold" Foreground="#FFB86C"/>
            <DockPanel HorizontalAlignment="Left">
                <TextBox x:Name="DownloadDirectoryText" MinWidth="420" IsReadOnly="True" Margin="20,10,0,10"/>
                <Button Content="Browse..." Width="100" DockPanel.Dock="Right" Click="Browse_Click"/>
            </DockPanel>
            <StackPanel Orientation="Vertical" Margin="0,8,0,0">
                <RadioButton x:Name="SingleFolderRadio" Content="Use a single folder for all downloads" IsChecked="True"/>
                <RadioButton x:Name="SubfoldersRadio" Content="Organize into subfolders per type (Video, Audio, Partial Video, Partial Audio)"/>
            </StackPanel>
        </StackPanel>

        <!-- Behavior Options -->
        <StackPanel Grid.Row="1" Margin="0,8,0,8">
            <TextBlock Text="Behavior" FontWeight="Bold" Foreground="#FFB86C"/>
            <CheckBox x:Name="AutoOpenCheck" Content="Automatically open folder and highlight file upon completion" Checked="AutoOpenCheck_Checked" Foreground="White"/>
            <CheckBox x:Name="AutoUpdateToolsCheck" Content="Automatically check/update yt-dlp &amp; ffmpeg" Foreground="White"/>
            <CheckBox x:Name="ConvertToMp4Check" Content="Convert all video downloads to .mp4" Foreground="White"/>
        </StackPanel>

        <!-- Simultaneous Downloads -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,8,0,8">
            <TextBlock Text="Number of simultaneous downloads:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="ConcurrentDownloadsCombo" Width="80">
                <ComboBoxItem Content="1"/>
                <ComboBoxItem Content="2"/>
                <ComboBoxItem Content="3"/>
            </ComboBox>
        </StackPanel>

        <!-- Tools (yt-dlp / ffmpeg) -->
        <StackPanel Grid.Row="3" Margin="0,8,0,8" >
            <TextBlock Text="Tools" FontWeight="Bold" Foreground="#FFB86C"/>

            <Grid Margin="0,6,0,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="13*"/>
                    <RowDefinition Height="22*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="yt-dlp:" VerticalAlignment="Top" Margin="5,8,5,0" Grid.RowSpan="2" Width="50"/>
                <TextBox x:Name="YtDlpPathText" Grid.Column="1" MinWidth="380" Margin="0,5,2,5" Grid.RowSpan="2" Width="380"/>
                <Button x:Name="BrowseYtBtn" Grid.Column="2" Content="Browse..." Margin="8,0,0,0" Width="100" Click="BrowseYtDlp_Click" Grid.RowSpan="2"/>
                <Button x:Name="GetYtBtn" Grid.Column="3" Content="Update" Margin="8,0,0,0" Width="110" Click="GetUpdateYtDlp_Click" Grid.RowSpan="2"/>
            </Grid>
            <TextBlock x:Name="YtDlpStatusText" FontSize="12" Foreground="#BFBFBF"/>

            <Grid Margin="0,10,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="ffmpeg:" VerticalAlignment="Center" Margin="5,0,5,0" Width="50"/>
                <TextBox x:Name="FfmpegPathText" Grid.Column="1" MinWidth="380" Width="380" Margin="0,5,0,5" TextChanged="FfmpegPathText_TextChanged"/>
                <Button x:Name="BrowseFfmpegBtn" Grid.Column="2" Content="Browse..." Margin="8,0,0,0" Width="100" Click="BrowseFfmpeg_Click"/>
                <Button x:Name="GetFfmpegBtn" Grid.Column="3" Content="Update" Margin="8,0,0,0" Width="110" Click="GetUpdateFfmpeg_Click"/>
            </Grid>
            <TextBlock x:Name="FfmpegStatusText" FontSize="12" Foreground="#BFBFBF"/>
        </StackPanel>


        <!-- Diagnostics -->
        <StackPanel Grid.Row="4" Margin="0,8,0,8">
            <TextBlock Text="Diagnostics" FontWeight="Bold" Foreground="#FFB86C"/>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                <Button Content="Open Log Folder" Width="140" Click="OpenLogFolder_Click"/>
                <TextBlock Text="Opens the folder containing error logs." Margin="12,5,0,0" Foreground="#BFBFBF"/>
            </StackPanel>
        </StackPanel>

        <!-- Bottom bar: version label + buttons -->
        <Grid Grid.Row="5" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="AppVersionText" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="#BFBFBF"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" Width="100" Click="Save_Click" Background="#50FA7B" Foreground="#282A36"/>
                <Button Content="Cancel" Width="100" Click="Cancel_Click" Background="#FF5555" Foreground="#282A36"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
